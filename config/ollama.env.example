# bin/ollama configuration (optional)
# Copy to config/ollama.env and adjust. Sourced by bin/ollama when present.

# Run all Ollama and Ruby commands through Docker (no host Ruby or Ollama required).
# Requires: homunculus-agent and homunculus-ollama containers running (e.g. bin/assistant up --with-ollama).
# 0 = auto-detect: use host Ollama/Ruby when available, else Docker
# 1 = always use Docker for Ollama and for Ruby (fleet parser, list table)
BIN_OLLAMA_USE_DOCKER=0

# Optional: override container names (defaults shown)
# OLLAMA_CONTAINER=homunculus-ollama
# AGENT_CONTAINER=homunculus-agent
