#!/usr/bin/env bash
set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; exit 1; }

# ---- Docker Compose (production) ----

COMPOSE_FILE="${COMPOSE_FILE:-docker-compose.yml}"

dc() {
  docker compose -f "$COMPOSE_FILE" "$@"
}

# Parse profile flags from argv; consume them and set COMPOSE_PROFILES.
# Call as: parse_profile_flags "$@" ; then use "$REMAINING_ARGS" for dc.
parse_profile_flags() {
  COMPOSE_PROFILES=()
  REMAINING_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --with-ollama)   COMPOSE_PROFILES+=(--profile ollama); shift ;;
      --with-searxng)  COMPOSE_PROFILES+=(--profile searxng); shift ;;
      --with-sandbox)  COMPOSE_PROFILES+=(--profile sandbox); shift ;;
      --with-ntfy)     COMPOSE_PROFILES+=(--profile ntfy); shift ;;
      --build)         REMAINING_ARGS+=(--build); shift ;;
      *)               REMAINING_ARGS+=("$1"); shift ;;
    esac
  done
}

# ---- Pre-flight (called before up/restart) ----

preflight() {
  docker info &>/dev/null || error "Docker is not running. Start the Docker daemon and try again."
  mkdir -p data workspace/memory
  [[ -f .env ]] || error "Missing .env file. Run 'bin/assistant setup' first."
  # Clean partial state: remove containers and orphan references, then prune stale networks
  dc down --remove-orphans 2>/dev/null || true
  docker network prune -f &>/dev/null || true
}

# Wait for homunculus-agent container to be running. Timeout in seconds.
wait_healthy() {
  local timeout="${1:-30}"
  local deadline
  deadline=$(($(date +%s) + timeout))
  while [[ $(date +%s) -lt $deadline ]]; do
    if docker ps --filter "name=homunculus-agent" --filter "status=running" -q 2>/dev/null | grep -q .; then
      info "Assistant is running."
      return 0
    fi
    sleep 2
  done
  warn "Timeout waiting for assistant to be running. Check: bin/assistant status"
  return 1
}

# ---- Lifecycle ----

cmd_setup() {
  docker info &>/dev/null || error "Docker is not running."
  mkdir -p data workspace/memory
  if [[ ! -f .env ]]; then
    info "Generating .env from .env.example..."
    cp .env.example .env
    local auth_token auth_hash
    auth_token=$(ruby -e "require 'securerandom'; puts SecureRandom.hex(32)")
    auth_hash=$(ruby -e "require 'bcrypt'; puts BCrypt::Password.create('$auth_token')")
    sed -i.bak "s|^GATEWAY_AUTH_TOKEN_HASH=.*|GATEWAY_AUTH_TOKEN_HASH=${auth_hash}|" .env
    rm -f .env.bak
    info "Auth token generated. Save this token securely:"
    echo ""
    echo -e "  ${YELLOW}${auth_token}${NC}"
    echo ""
    warn "This token will NOT be shown again."
  else
    info ".env already exists, skipping."
  fi
  cmd_build "$@"
  if command -v ollama &>/dev/null; then
    local model="qwen2.5:14b"
    if ollama list 2>/dev/null | grep -q "$model"; then
      info "Ollama model $model already available."
    else
      info "Pulling Ollama model $model (this may take a while)..."
      ollama pull "$model" || warn "Failed to pull model. You can pull later with: ollama pull $model"
    fi
  else
    warn "Ollama not found on host. Use 'bin/assistant up --with-ollama' to run Ollama in Docker."
  fi
  echo ""
  info "Setup complete. Start with: bin/assistant up"
}

cmd_build() {
  parse_profile_flags "$@"
  if [[ ${#REMAINING_ARGS[@]} -gt 0 ]]; then
    dc build "${REMAINING_ARGS[@]}"
  else
    dc build
  fi
  info "Build complete."
}

cmd_up() {
  preflight
  parse_profile_flags "$@"
  dc "${COMPOSE_PROFILES[@]}" up -d "${REMAINING_ARGS[@]}"
  wait_healthy 30
  info "Assistant is up. Gateway: http://127.0.0.1:18789"
}

cmd_down() {
  parse_profile_flags "$@"
  dc "${COMPOSE_PROFILES[@]}" down "${REMAINING_ARGS[@]}"
  info "Assistant stopped."
}

cmd_restart() {
  cmd_down "$@"
  cmd_up "$@"
}

cmd_regenerate() {
  cmd_build "$@"
  cmd_restart "$@"
}

# ---- Recovery / Failover ----

cmd_doctor() {
  local ok=0
  echo "Homunculus Assistant — Diagnostics"
  echo "===================================="
  if docker info &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} Docker daemon reachable"
  else
    echo -e "  ${RED}✗${NC} Docker daemon not reachable"
    ok=1
  fi
  if docker compose version &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} Docker Compose: $(docker compose version --short 2>/dev/null || echo 'ok')"
  else
    echo -e "  ${RED}✗${NC} Docker Compose not found"
    ok=1
  fi
  if [[ -f .env ]]; then
    echo -e "  ${GREEN}✓${NC} .env present"
  else
    echo -e "  ${YELLOW}!${NC} .env missing (run 'bin/assistant setup')"
    ok=1
  fi
  echo ""
  echo "Containers:"
  dc ps -a 2>/dev/null || true
  echo ""
  if command -v ss &>/dev/null; then
    if ss -tln 2>/dev/null | grep -q ':18789'; then
      echo -e "  ${GREEN}✓${NC} Port 18789 in use (gateway)"
    else
      echo -e "  ${YELLOW}!${NC} Port 18789 not bound"
    fi
    if ss -tln 2>/dev/null | grep -q ':11434'; then
      echo -e "  ${GREEN}✓${NC} Port 11434 in use (Ollama)"
    else
      echo -e "  ${YELLOW}!${NC} Port 11434 not bound (Ollama not running?)"
    fi
    if ss -tln 2>/dev/null | grep -q ':8888'; then
      echo -e "  ${GREEN}✓${NC} Port 8888 in use (SearXNG)"
    else
      echo -e "  ${YELLOW}!${NC} Port 8888 not bound (SearXNG not running?)"
    fi
    if ss -tln 2>/dev/null | grep -q ':2586'; then
      echo -e "  ${GREEN}✓${NC} Port 2586 in use (ntfy)"
    else
      echo -e "  ${YELLOW}!${NC} Port 2586 not bound (ntfy not running?)"
    fi
  fi
  if docker ps --filter "name=homunculus-agent" --filter "status=running" -q 2>/dev/null | grep -q .; then
    echo ""
    echo "Ollama reachability (from host):"
    if curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 http://127.0.0.1:11434/api/tags 2>/dev/null | grep -q 200; then
      echo -e "  ${GREEN}✓${NC} Ollama API reachable at 127.0.0.1:11434"
    else
      echo -e "  ${YELLOW}!${NC} Ollama not reachable at 127.0.0.1:11434"
    fi
    echo ""
    echo "SearXNG reachability (from host):"
    if curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 http://127.0.0.1:8888/healthz 2>/dev/null | grep -q 200; then
      echo -e "  ${GREEN}✓${NC} SearXNG reachable at 127.0.0.1:8888/healthz"
    else
      echo -e "  ${YELLOW}!${NC} SearXNG not reachable at 127.0.0.1:8888/healthz"
    fi
    echo ""
    echo "ntfy reachability (from host):"
    if curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 http://127.0.0.1:2586 2>/dev/null | grep -qE '2[0-9][0-9]|401|403'; then
      echo -e "  ${GREEN}✓${NC} ntfy reachable at 127.0.0.1:2586"
      echo -e "  ${GREEN}✓${NC} Subscribe at: http://localhost:2586 (topic: homunculus)"
    else
      echo -e "  ${YELLOW}!${NC} ntfy not reachable at 127.0.0.1:2586 (use --with-ntfy to start)"
    fi
  fi
  echo ""
  [[ $ok -eq 0 ]] || exit 1
}

cmd_obliterate() {
  local do_volumes=()
  local confirmed=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --confirm) confirmed=1; shift ;;
      --volumes) do_volumes=(--volumes); shift ;;
      *) shift ;;
    esac
  done
  [[ -n "$confirmed" ]] || error "Obliterate requires --confirm. Use: bin/assistant obliterate --confirm"
  warn "Stopping all profiles and removing containers/networks..."
  dc --profile ollama --profile searxng --profile sandbox --profile ntfy down --remove-orphans "${do_volumes[@]}"
  docker network prune -f
  if [[ ${#do_volumes[@]} -gt 0 ]]; then
    warn "Volumes removed. Data (memory, audit, scheduler) has been deleted."
  fi
  info "Obliterate complete. Start fresh with: bin/assistant up"
}

# ---- Observability ----

cmd_status() {
  echo "Homunculus Assistant — Status"
  echo "============================="
  dc ps -a
  echo ""
  echo "Profiles: use --with-ollama, --with-searxng, and/or --with-sandbox with 'up' to start optional services."
}

cmd_logs() {
  dc logs -f "$@"
}

cmd_ps() {
  dc ps "$@"
}

cmd_validate() {
  if ! docker ps --filter "name=homunculus-agent" --filter "status=running" -q 2>/dev/null | grep -q .; then
    error "Assistant container is not running. Start with: bin/assistant up"
  fi
  dc exec homunculus-agent bundle exec ruby bin/homunculus validate
}

cmd_shell() {
  if ! docker ps --filter "name=homunculus-agent" --filter "status=running" -q 2>/dev/null | grep -q .; then
    error "Assistant container is not running. Start with: bin/assistant up"
  fi
  dc exec homunculus-agent bash
}

cmd_cli() {
  if ! docker ps --filter "name=homunculus-agent" --filter "status=running" -q 2>/dev/null | grep -q .; then
    error "Assistant container is not running. Start with: bin/assistant up"
  fi
  dc exec -it homunculus-agent bundle exec ruby bin/homunculus cli "$@"
}

cmd_tui() {
  if ! docker ps --filter "name=homunculus-agent" --filter "status=running" -q 2>/dev/null | grep -q .; then
    error "Assistant container is not running. Start with: bin/assistant up"
  fi
  dc exec -it homunculus-agent bundle exec ruby bin/homunculus tui "$@"
}

# ---- Info ----

cmd_help() {
  cat <<EOF
Usage: bin/assistant <command> [args]

Lifecycle:
  setup              First-run: create .env, build images, pull Ollama model
  build [args]       Build production images (pass --with-ollama/--with-searxng/--with-sandbox for profiles)
  up [args]          Pre-flight + start. Use --with-ollama, --with-searxng, --with-sandbox, --with-ntfy, --build
  down [args]        Stop services (preserves volumes)
  restart [args]     Down then up (pass same flags as up)
  regenerate [args]  Build images then restart (down + up with same flags)

Recovery:
  doctor             Diagnostic report: Docker, compose, .env, containers, ports, Ollama, SearXNG, ntfy
  obliterate         Nuclear cleanup: stop all, remove containers/networks (requires --confirm)
                     Add --volumes to also remove data volumes (destructive)

Observability:
  status             Container states and profiles
  logs [service]     Tail logs (e.g. homunculus-agent)
  ps [args]          Raw docker compose ps
  validate           Run config validation inside running container
  shell              Open bash in the running agent container
  cli [args]         Interactive CLI (pass --provider, --model as needed)
  tui [args]         Full-screen TUI (pass --provider, --model as needed)

Info:
  help               Show this help

Examples:
  bin/assistant setup
  bin/assistant up --with-ollama
  bin/assistant up --with-searxng
  bin/assistant up --with-ollama --with-searxng
  bin/assistant up --with-ntfy
  bin/assistant up --with-ollama --with-searxng --with-sandbox --build
  bin/assistant obliterate --confirm
  bin/assistant doctor
  bin/assistant logs homunculus-agent
  bin/assistant cli
  bin/assistant tui --model qwen2.5:14b
EOF
}

# ---- Dispatch ----

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  setup)      cmd_setup "$@" ;;
  build)      cmd_build "$@" ;;
  up)         cmd_up "$@" ;;
  down)       cmd_down "$@" ;;
  restart)    cmd_restart "$@" ;;
  regenerate) cmd_regenerate "$@" ;;
  doctor)     cmd_doctor "$@" ;;
  obliterate) cmd_obliterate "$@" ;;
  status)     cmd_status "$@" ;;
  logs)       cmd_logs "$@" ;;
  ps)         cmd_ps "$@" ;;
  validate)   cmd_validate "$@" ;;
  shell)      cmd_shell "$@" ;;
  cli)        cmd_cli "$@" ;;
  tui)        cmd_tui "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    error "Unknown command: $COMMAND. Run 'bin/assistant help' for usage."
    ;;
esac
